// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"                 // postgres
  url      = env("DATABASE_URL")
}

/* Definicion de tablas mediante JS*/
model Usuario {
  id Int     @id @default(autoincrement())
  nombreUsuario    String  @db.VarChar(100) @unique
  password  String  @db.VarChar(100)
  email     String  @db.VarChar(100)
  nombre String  @db.VarChar(100) 
  apellido String  @db.VarChar(100) 
  dni Int 
  telefono  String  @db.VarChar(50)
  fechaCreacion DateTime @default(now())
  fechaActualizacion DateTime?
  fechaEliminacion DateTime?
  cuota Cuota[]
  estadoUsuario EstadoUsuario[]
  UsuarioRol UsuarioRol[]
  Socio Socio[]
}

enum EstadoValorUser{
  Pendiente         /*cuando se registre y aun no haya hecho la verificacion con mail */
  Activo
  Deudor
  Suspendido
  Inactivo
}
model EstadoUsuario{
  idEstado Int @id @default(autoincrement())
  valor      EstadoValorUser
  idUsuario Int
  fechaCambio DateTime @default(now())  /* es la fechaCambio-fechaCre de estado */
  /* fechaActualizacion DateTime? */
  fechaEliminacion DateTime?
  usuario      Usuario    @relation(fields: [idUsuario], references: [id])
}

/* ~~~~~~~ ROLES: sirven ~~~~~~~*/
enum NombreRol{
  Admin
  Socio
  Invitado    /* No socio */
}
model Rol {
  id Int @id @default(autoincrement())
  nombre NombreRol
  fechaCreacion DateTime @default(now()) 
  /* fechaActualizacion DateTime? */
  fechaEliminacion DateTime?
  UsuarioRol UsuarioRol[]
}

model UsuarioRol {            /* No solo refleja la relacion User*---*Rol sino q tambien es un historial de estados de Rol   */
  idUsuario Int               
  idRol     Int
  fechaInicio DateTime @default(now()) 
  fechaFin DateTime?
  fechaCreacion DateTime @default(now()) 
  fechaActualizacion DateTime?
  fechaEliminacion DateTime?
  usuario   Usuario @relation(fields: [idUsuario], references: [id])
  rol       Rol     @relation(fields: [idRol], references: [id])
  @@id([idUsuario, idRol]) // Clave primaria compuesta
}

/* ~~~~~~ENTIDAD SOCIO: sirve para traer su Numero/Legajo identificatorio ~~~~~~~~*/
model Socio {                                      
  numero Int @id @default(autoincrement())
  idUsuario Int @unique
  fechaAlta DateTime @default(now())   /* su historial estando de os */
  fechaBaja DateTime? 
  fechaCreacion DateTime @default(now()) 
  fechaActualizacion DateTime?
  fechaEliminacion DateTime?
  usuario Usuario @relation(fields: [idUsuario], references: [id])
}
/*~~~~~~~~~~~~~~*/
model Cuota{
  id Int @id @default(autoincrement())
  fechaInicio DateTime  // mal usar @unique ak xq fechaInicio se repite en cada user,sino hacer (unique@(idUser,idCuota))
  fechaVencimiento DateTime
  fechaCreacion DateTime @default(now())
  montoTotal Decimal @db.Decimal(10,2) @default(0)
  idUsuario Int
  idValorCuota Int
  usuario     Usuario    @relation(fields: [idUsuario], references: [id])
  valorCuota      ValorCuota     @relation(fields: [idValorCuota], references: [id])
  lineaDeCuota LineaDeCuota[]
  estadoCuota EstadoCuota[]
}

enum EstadoValorCuota{
  Pendiente
  Pagada
  Pagada_Parcial
  Adeudada
  Cancelada
}

model EstadoCuota{
  idEstado Int @id @default(autoincrement())
  fechaCambio DateTime @default(now()) 
  valor      EstadoValorCuota
  idCuota Int
  cuota      Cuota    @relation(fields: [idCuota], references: [id])
}

model LineaDeCuota{
  id Int @id @default(autoincrement())
  idCuota Int
  fechaPago DateTime 
  fechaCreacion DateTime @default(now())
  monto     Decimal @db.Decimal(10,2)
  metodoPago  String @db.VarChar(30)
  cuota     Cuota    @relation(fields: [idCuota], references: [id])
}

model ValorCuota{
  id Int @id @default(autoincrement())
  precio Decimal @db.Decimal(10,2)
  fechaCreacion DateTime @unique @default(now())   /* fechaCambio */
  fechaActualizacion DateTime?
  fechaEliminacion DateTime?
  cuotas       Cuota[] 
}
