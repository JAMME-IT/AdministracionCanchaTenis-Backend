// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"                 // postgres
  url      = env("DATABASE_URL")
}

// Definicion de tablas mediante JS
model Usuario {
  id Int     @id @default(autoincrement())
  email     String  @db.VarChar(255) @unique
  password  String  @db.VarChar(255)
  nombre String  @db.VarChar(255) 
  apellido String  @db.VarChar(255) 
  dni Int @unique
  telefono  String  @db.VarChar(50)
  fechaCreacion DateTime @default(now())
  fechaActualizacion DateTime @updatedAt 
  fechaEliminacion DateTime?
  estadoUsuario EstadoUsuario[]
  UsuarioRol UsuarioRol[]
  Socio Socio?
}

enum EstadoValorUser{ 
  Activo
  Inactivo
}
model EstadoUsuario{
  idEstado Int @id @default(autoincrement())
  valor      EstadoValorUser
  idUsuario Int
  fechaCambio DateTime @default(now())  // es la fechaCambio-fechaCre de estado 
  fechaActualizacion DateTime @updatedAt
  fechaEliminacion DateTime?
  usuario      Usuario    @relation(fields: [idUsuario], references: [id])
}

// ~~~~~~~ ROLES:control de roles ~~~~~~~
enum NombreRol{
  Admin
  Socio
  Invitado    // No socio 
}
model Rol {
  id Int @id @default(autoincrement())
  nombre NombreRol @unique
  fechaCreacion DateTime @default(now()) 
  fechaActualizacion DateTime @updatedAt
  fechaEliminacion DateTime?
  UsuarioRol UsuarioRol[]
}

model UsuarioRol {            // No solo refleja la relacion User*---*Rol sino q tambien es un historial de estados de Rol   
  idUsuario Int     
  idRol     Int          
  fechaInicio DateTime @default(now()) 
  fechaFin DateTime?
  fechaCreacion DateTime @default(now()) 
  fechaActualizacion DateTime @updatedAt
  fechaEliminacion DateTime?
  usuario   Usuario @relation(fields: [idUsuario], references: [id])
  rol       Rol     @relation(fields: [idRol], references: [id])
  @@id([idUsuario, idRol]) // Clave primaria compuesta
}

// ~~~~~~ENTIDAD SOCIO: el socio como tal tiene su Numero/Legajo identificatorio y demas info ~~~~~~~~
model Socio {                                      
  numeroSocio Int @id @default(autoincrement())
  fechaAlta DateTime @default(now())   // 
  fechaBaja DateTime? 
  estado String @db.VarChar(20) 

  fechaCreacion DateTime @default(now()) 
  fechaActualizacion DateTime @updatedAt
  fechaEliminacion DateTime?
  idUsuario Int @unique   // Relacion Socio 0..1 ---- 1 Usuario 
  usuario Usuario @relation(fields: [idUsuario], references: [id])
  cuota Cuota[]
}
// ~~~~~~~~~~~~~~
model Cuota{
  id Int @id @default(autoincrement())
  fechaInicio DateTime  // mal usar @unique ak xq fechaInicio se repite en cada user,sino hacer (unique@(idUser,idCuota))
  fechaVencimiento DateTime
  montoTotal Decimal @db.Decimal(10,2) @default(0)
  fechaCreacion DateTime @default(now())  
  fechaActualizacion DateTime @updatedAt
  fechaEliminacion DateTime?
  idUsuario Int
  idValorCuota Int
  numeroSocio Int
  socio            Socio    @relation(fields: [numeroSocio], references: [numeroSocio])
  valorCuota      ValorCuota     @relation(fields: [idValorCuota], references: [id])
  lineaDeCuota LineaDeCuota[]
  estadoCuota EstadoCuota[]
}

enum EstadoValorCuota{
  Pendiente
  Pagada
  Pagada_Parcial
  Adeudada
  Cancelada
}

model EstadoCuota{
  idEstado Int @id @default(autoincrement())
  valor      EstadoValorCuota
  fechaCreacion DateTime @default(now())  // fechaCambio 
  fechaActualizacion DateTime @updatedAt
  fechaEliminacion DateTime?
  idCuota Int
  cuota      Cuota    @relation(fields: [idCuota], references: [id])
}

model LineaDeCuota{
  id Int @id @default(autoincrement())
  fechaPago DateTime 
  monto     Decimal @db.Decimal(10,2)
  metodoPago  String @db.VarChar(30)
  fechaCreacion DateTime @default(now())
  fechaActualizacion DateTime @updatedAt
  fechaEliminacion DateTime?
  idCuota Int
  cuota     Cuota    @relation(fields: [idCuota], references: [id])
}

model ValorCuota{
  id Int @id @default(autoincrement())
  precio Decimal @db.Decimal(10,2)
  fechaCreacion DateTime @default(now())   
  fechaActualizacion DateTime @updatedAt
  fechaEliminacion DateTime?
  cuotas       Cuota[] 
}